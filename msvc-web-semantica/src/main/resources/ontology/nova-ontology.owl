<?xml version="1.0"?>
<rdf:RDF xmlns="http://nova.ing/ontology/"
     xml:base="http://nova.ing/ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:schema="http://schema.org/"
     xmlns:time="http://www.w3.org/2006/time#">
    
    <owl:Ontology rdf:about="http://nova.ing/ontology/">
        <rdfs:comment xml:lang="es">Ontologia principal para el sistema de gestion de atencion medica NOVA.</rdfs:comment>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Clases Principales
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <!-- http://nova.ing/ontology/Paciente -->
    <owl:Class rdf:about="http://nova.ing/ontology/Paciente">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <owl:equivalentClass rdf:resource="http://schema.org/Patient"/>
        <rdfs:label xml:lang="es">Paciente</rdfs:label>
    </owl:Class>

    <!-- http://nova.ing/ontology/PacienteCronico -->
    <owl:Class rdf:about="http://nova.ing/ontology/PacienteCronico">
        <rdfs:subClassOf rdf:resource="http://nova.ing/ontology/Paciente"/>
        <rdfs:label xml:lang="es">Paciente con Enfermedad Cronica</rdfs:label>
    </owl:Class>

    <!-- http://nova.ing/ontology/ProfesionalSalud -->
    <owl:Class rdf:about="http://nova.ing/ontology/ProfesionalSalud">
        <rdfs:subClassOf rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <owl:equivalentClass rdf:resource="http://schema.org/MedicalOrganization"/>
        <rdfs:label xml:lang="es">Profesional de la Salud</rdfs:label>
    </owl:Class>

    <!-- http://nova.ing/ontology/Medico -->
    <owl:Class rdf:about="http://nova.ing/ontology/Medico">
        <rdfs:subClassOf rdf:resource="http://nova.ing/ontology/ProfesionalSalud"/>
        <owl:equivalentClass rdf:resource="http://schema.org/Physician"/>
        <rdfs:label xml:lang="es">Medico</rdfs:label>
    </owl:Class>

    <!-- http://nova.ing/ontology/EventoClinico -->
    <owl:Class rdf:about="http://nova.ing/ontology/EventoClinico">
        <owl:equivalentClass rdf:resource="http://schema.org/MedicalEvent"/>
        <rdfs:label xml:lang="es">Evento Clinico</rdfs:label>
    </owl:Class>

    <!-- http://nova.ing/ontology/Cita -->
    <owl:Class rdf:about="http://nova.ing/ontology/Cita">
        <rdfs:subClassOf rdf:resource="http://nova.ing/ontology/EventoClinico"/>
        <rdfs:label xml:lang="es">Cita Medica</rdfs:label>
    </owl:Class>

    <!-- http://nova.ing/ontology/Diagnostico -->
    <owl:Class rdf:about="http://nova.ing/ontology/Diagnostico">
        <owl:equivalentClass rdf:resource="http://schema.org/MedicalCondition"/>
        <rdfs:label xml:lang="es">Diagnostico Medico</rdfs:label>
    </owl:Class>

    <!-- http://nova.ing/ontology/Horario -->
    <owl:Class rdf:about="http://nova.ing/ontology/Horario">
        <rdfs:label xml:lang="es">Horario de Atencion</rdfs:label>
    </owl:Class>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Listas de Valores (Enums)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:Class rdf:about="http://nova.ing/ontology/EspecialidadMedico">
        <rdfs:label xml:lang="es">Especialidad Medica</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://nova.ing/ontology/EstadoMedico">
        <rdfs:label xml:lang="es">Estado del Medico</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://nova.ing/ontology/EstadoPaciente">
        <rdfs:label xml:lang="es">Estado del Paciente</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://nova.ing/ontology/EstadoCita">
        <rdfs:label xml:lang="es">Estado de la Cita</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://nova.ing/ontology/TipoDiagnostico">
        <rdfs:label xml:lang="es">Tipo de Diagnostico</rdfs:label>
    </owl:Class>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Propiedades de Datos
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/nombres">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Nombres</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/apellidos">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Apellidos</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/fechaNacimiento">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="es">Fecha de Nacimiento</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/genero">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Genero</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/dni">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Documento Nacional de Identidad</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/telefono">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Telefono de Contacto</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/email">
        <rdfs:domain rdf:resource="http://xmlns.com/foaf/0.1/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Correo Electronico</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/direccion">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Paciente"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Direccion de Residencia</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/fechaCita">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Cita"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="es">Fecha y Hora de la Cita</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/horaInicio">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://nova.ing/ontology/Cita"/>
                    <rdf:Description rdf:about="http://nova.ing/ontology/Horario"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Hora de Inicio</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/horaFin">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://nova.ing/ontology/Cita"/>
                    <rdf:Description rdf:about="http://nova.ing/ontology/Horario"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Hora de Fin</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/motivo">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Cita"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Motivo de la Cita</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/descripcion">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Diagnostico"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Descripcion del Diagnostico</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/fechaDiagnostico">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Diagnostico"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:label xml:lang="es">Fecha del Diagnostico</rdfs:label>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://nova.ing/ontology/diaSemana">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Horario"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="es">Dia de la Semana</rdfs:label>
    </owl:DatatypeProperty>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Propiedades de Objeto (Relaciones)
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/paciente">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://nova.ing/ontology/Cita"/>
                    <rdf:Description rdf:about="http://nova.ing/ontology/Diagnostico"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://nova.ing/ontology/Paciente"/>
        <rdfs:label xml:lang="es">Tiene Paciente Asignado</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/medico">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Cita"/>
        <rdfs:range rdf:resource="http://nova.ing/ontology/Medico"/>
        <rdfs:label xml:lang="es">Tiene Medico Asignado</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/cita">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Diagnostico"/>
        <rdfs:range rdf:resource="http://nova.ing/ontology/Cita"/>
        <rdfs:label xml:lang="es">Asociado a Cita</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/tieneHorario">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Medico"/>
        <rdfs:range rdf:resource="http://nova.ing/ontology/Horario"/>
        <rdfs:label xml:lang="es">Tiene Horario Disponible</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/horarioDe">
        <owl:inverseOf rdf:resource="http://nova.ing/ontology/tieneHorario"/>
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Horario"/>
        <rdfs:range rdf:resource="http://nova.ing/ontology/Medico"/>
        <rdfs:label xml:lang="es">Es Horario De</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/estado">
        <rdfs:label xml:lang="es">Tiene Estado</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/especialidad">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Medico"/>
        <rdfs:range rdf:resource="http://nova.ing/ontology/EspecialidadMedico"/>
        <rdfs:label xml:lang="es">Tiene Especialidad</rdfs:label>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://nova.ing/ontology/tipoDiagnostico">
        <rdfs:domain rdf:resource="http://nova.ing/ontology/Diagnostico"/>
        <rdfs:range rdf:resource="http://nova.ing/ontology/TipoDiagnostico"/>
        <rdfs:label xml:lang="es">Tiene Tipo de Diagnostico</rdfs:label>
    </owl:ObjectProperty>

</rdf:RDF>
