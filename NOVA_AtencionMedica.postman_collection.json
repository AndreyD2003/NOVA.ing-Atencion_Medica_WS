					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"if (pm.environment.get('token_patient')) {",
									"    pm.request.headers.add({key: 'Authorization', value: 'Bearer ' + pm.environment.get('token_patient')});",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Cambiar estado por paciente -> 200 OK', function () {",
