						"body": {
							"mode": "raw",
							"raw": "{\n    \"query\": \"PREFIX onto: <http://nova.ing/ontology/> SELECT ?nombre ?apellido WHERE { ?p a onto:Paciente ; onto:nombres ?nombre ; onto:apellidos ?apellido . }\"\n}"
